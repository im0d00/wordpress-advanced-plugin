{
  "name": "nexusbuilder",
  "version": "1.0.0",
  "description": "Next-generation WordPress page builder",
  "private": true,
  "scripts": {
    "build":         "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "dev":           "cross-env NODE_ENV=development webpack --config webpack.config.js --watch",
    "test":          "jest --coverage --passWithNoTests",
    "test:e2e":      "playwright test",
    "lint":          "eslint assets/editor/src --ext .ts,.tsx --fix",
    "typecheck":     "tsc --noEmit",
    "format":        "prettier --write 'assets/editor/src/**/*.{ts,tsx,css}'",
    "zip":           "node scripts/build-zip.js",
    "i18n":          "node scripts/generate-pot.js",
    "analyze":       "cross-env ANALYZE=true npm run build"
  },
  "dependencies": {
    "@dnd-kit/core":       "^6.1.0",
    "@dnd-kit/sortable":   "^8.0.0",
    "@dnd-kit/utilities":  "^3.2.2",
    "@tiptap/core":        "^2.4.0",
    "@tiptap/react":       "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "gsap":                "^3.12.5",
    "nanoid":              "^5.0.7",
    "react":               "^18.3.1",
    "react-dom":           "^18.3.1",
    "zustand":             "^4.5.4",
    "zundo":               "^2.2.0"
  },
  "devDependencies": {
    "@playwright/test":             "^1.45.0",
    "@types/react":                 "^18.3.3",
    "@types/react-dom":             "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser":        "^7.16.0",
    "babel-jest":                   "^29.7.0",
    "copy-webpack-plugin":          "^12.0.2",
    "cross-env":                    "^7.0.3",
    "css-loader":                   "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "eslint":                       "^9.7.0",
    "eslint-plugin-react":          "^7.35.0",
    "eslint-plugin-react-hooks":    "^4.6.2",
    "jest":                         "^29.7.0",
    "jest-environment-jsdom":       "^29.7.0",
    "mini-css-extract-plugin":      "^2.9.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "prettier":                     "^3.3.3",
    "style-loader":                 "^4.0.0",
    "terser-webpack-plugin":        "^5.3.10",
    "ts-jest":                      "^29.2.3",
    "ts-loader":                    "^9.5.1",
    "typescript":                   "^5.5.3",
    "webpack":                      "^5.93.0",
    "webpack-bundle-analyzer":      "^4.10.2",
    "webpack-cli":                  "^5.1.4"
  }
}
